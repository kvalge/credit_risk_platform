# PostgreSQL
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name

# Airflow (3.x Simple Auth Manager: each entry is username:role, not username:password)
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS=admin:admin
AIRFLOW_WWW_USER_USERNAME=your_airflow_username
AIRFLOW_WWW_USER_PASSWORD=your_airflow_password
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://user:password@postgres/dbname
# Airflow 3 execution API auth (must be the same across all airflow services)
AIRFLOW__API_AUTH__JWT_SECRET=your_random_jwt_secret_here

# dbt
DBT_POSTGRES_HOST=postgres
DBT_POSTGRES_USER=your_postgres_user
DBT_POSTGRES_PASSWORD=your_postgres_password
DBT_POSTGRES_DB=your_database_name
DBT_POSTGRES_PORT=5432