FROM python:3.13-slim

WORKDIR /opt/dbt

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install dbt with postgres adapter
RUN pip install --no-cache-dir \
    dbt-core \
    dbt-postgres

CMD ["dbt", "debug"]